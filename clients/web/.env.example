# yunmao Web 客户端环境变量（Next.js）
# 复制为 .env.local 填写真实值

# API 基础地址（浏览器端调用）
# 开发环境：http://localhost:8100（gateway 或 nginx 代理）
# 生产环境：https://yunmao.net.cn
NEXT_PUBLIC_API_BASE=http://localhost:8100

# WebSocket 基础地址（实时通信）
# 开发环境：ws://localhost:8090（gateway 直连）
# 生产环境：wss://yunmao.net.cn/ws
NEXT_PUBLIC_WS_BASE=ws://localhost:8090

# HLS / WHEP 播放基础地址（可选，默认同 API 域名）
# 开发环境：http://localhost:8080（media-edge）
# 生产环境：https://yunmao.net.cn
NEXT_PUBLIC_MEDIA_BASE=http://localhost:8080

# 调试开关（仅开发环境）
# NEXT_PUBLIC_DEBUG=true
