# yunmao Admin 客户端环境变量（Next.js）
# 复制为 .env.local 填写真实值

# Admin API 基础地址（浏览器端调用）
# 开发环境：http://localhost:8105（admin-svc 直连）
# 生产环境：https://yunmao.net.cn/admin-api
NEXT_PUBLIC_ADMIN_API_BASE=http://localhost:8105

# Admin 站点部署路径。
# 生产环境建议固定为 /admin，这样无需额外申请子域名。
YUNMAO_ADMIN_BASE_PATH=

# 调试开关（仅开发环境）
# NEXT_PUBLIC_DEBUG=true
