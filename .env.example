# yunmao 环境变量模板
# 复制为 .env 并填写真实值
# 所有变量前缀 YUNMAO_ 表示服务级配置

# ============================================================================
# 基础设施连接
# ============================================================================

# PostgreSQL 连接串（所有 Go 服务共享）
YUNMAO_DB_URL=postgres://yunmao:yunmao@localhost:5432/yunmao?sslmode=disable

# Redis 连接串（feeding-svc / chat-svc / device-svc 缓存）
YUNMAO_REDIS_URL=redis://localhost:6379/0

# Kafka 集群地址（事件总线）
YUNMAO_KAFKA_BROKERS=localhost:9092

# MQTT broker（设备服务）
YUNMAO_MQTT_BROKERS=tcp://localhost:1883
YUNMAO_MQTT_USERNAME=
YUNMAO_MQTT_PASSWORD=

# ============================================================================
# JWT 认证（ADR-0019：仅支持 RS256）
# ============================================================================

# JWT 算法（固定 RS256）
YUNMAO_JWT_ALG=RS256

# RS256 密钥（从 KMS 或文件加载）
YUNMAO_JWT_RS_KID=yunmao-user-svc
YUNMAO_JWT_RS_PRIVATE_KEY_PATH=/run/secrets/jwt-rs-private.pem

# Token 有效期（可选，默认 24h）
# YUNMAO_JWT_TOKEN_TTL=24h

# JWT audience（网关校验用）
YUNMAO_JWT_AUDIENCE=yunmao.gateway

# ============================================================================
# 服务监听端口
# ============================================================================

YUNMAO_USER_LISTEN=:8101
YUNMAO_ROOM_LISTEN=:8102
YUNMAO_DEVICE_LISTEN=:8103
YUNMAO_BILLING_LISTEN=:8104
YUNMAO_ADMIN_LISTEN=:8105
YUNMAO_CHAT_LISTEN=:8204
YUNMAO_FEEDING_LISTEN=:8201
YUNMAO_FEEDING_GRPC_LISTEN=:9203

# ============================================================================
# Rust 数据面（RUST_LOG 控制日志级别）
# ============================================================================

RUST_LOG=info,yunmao=debug
YUNMAO_GATEWAY_LISTEN=0.0.0.0:8090
YUNMAO_DEVICE_EDGE_LISTEN=0.0.0.0:8091

# ============================================================================
# TURN 服务（WebRTC ICE 穿透）
# ============================================================================

# 主密钥（用于生成临时凭据）
YUNMAO_TURN_SHARED_SECRET=
# 旧密钥（轮换窗口期内保留）
YUNMAO_TURN_SHARED_SECRET_LEGACY=

# ============================================================================
# 支付渠道（Phase D 凭据准备，详见 credential-cutover.md）
# ============================================================================

# 微信支付
YUNMAO_ENABLE_WECHAT=false
YUNMAO_WECHAT_MCH_ID=
YUNMAO_WECHAT_APIV3_KEY=
YUNMAO_WECHAT_SERIAL_NO=
YUNMAO_WECHAT_API_CLIENT_KEY_PATH=
YUNMAO_WECHAT_PLATFORM_PUBLIC_KEY_PATH=
YUNMAO_WECHAT_NOTIFY_URL=

# 支付宝
YUNMAO_ENABLE_ALIPAY=false
YUNMAO_ALIPAY_APP_ID=
YUNMAO_ALIPAY_PRIVATE_KEY_PEM_PATH=
YUNMAO_ALIPAY_PUBLIC_KEY_PATH=
YUNMAO_ALIPAY_NOTIFY_URL=

# Apple IAP
YUNMAO_ENABLE_APPLEIAP=false
YUNMAO_APPLE_BUNDLE_ID=
YUNMAO_APPLE_APP_APPLE_ID=
YUNMAO_APPLE_ROOT_CA_PATH=

# ============================================================================
# 迁移与数据库
# ============================================================================

# 迁移文件目录（默认 go/migrations）
YUNMAO_MIGRATIONS_DIR=

# ============================================================================
# 管理后台
# ============================================================================

# 初始管理员密码（首次启动时设置，后续可通过 API 修改）
YUNMAO_ADMIN_PASSWORD=

# 后台服务地址（admin-svc 调用其他服务）
YUNMAO_BILLING_URL=http://localhost:8104
YUNMAO_ROOM_URL=http://localhost:8102

# ============================================================================
# 调试与观测（开发环境可开启）
# ============================================================================

# 是否允许访客模式（仅开发/测试）
# YUNMAO_ALLOW_GUEST=true
# YUNMAO_GATEWAY_ALLOW_GUEST=true
# YUNMAO_GATEWAY_GUEST_ROOMS=room_demo

# 事件总线类型（默认 in-process，生产用 kafka）
# YUNMAO_EVENT_BUS=kafka

# 缓存后端（默认 in-process，生产用 redis）
# YUNMAO_CACHE_BACKEND=redis
