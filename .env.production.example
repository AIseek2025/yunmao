# yunmao ECS 生产环境模板
# 复制为 .env.production，并在 ECS 上填写真实值。

YUNMAO_DB_NAME=yunmao
YUNMAO_DB_USER=yunmao
YUNMAO_DB_PASSWORD=replace-with-strong-password
YUNMAO_DB_URL=postgres://yunmao:replace-with-strong-password@postgres-prod:5432/yunmao?sslmode=disable

YUNMAO_JWT_ALG=RS256
YUNMAO_JWT_RS_KID=yunmao-user-svc
YUNMAO_JWT_RS_PRIVATE_KEY_PATH=/run/secrets/jwt-rs-private.pem
YUNMAO_JWT_AUDIENCE=yunmao.gateway
YUNMAO_JWKS_ENDPOINTS=http://user-svc:8101/jwks.json

YUNMAO_ALLOW_GUEST=true
YUNMAO_GATEWAY_ALLOW_GUEST=true
YUNMAO_GATEWAY_GUEST_ROOMS=room_demo

YUNMAO_ADMIN_PASSWORD=replace-with-strong-admin-password
YUNMAO_SECRETS_DIR=/opt/yunmao/shared/secrets

YUNMAO_ENABLE_WECHAT=false
YUNMAO_ENABLE_ALIPAY=false
YUNMAO_ENABLE_APPLEIAP=false

NEXT_PUBLIC_API_BASE=https://yunmao.net.cn
NEXT_PUBLIC_WS_BASE=wss://yunmao.net.cn/ws
NEXT_PUBLIC_MEDIA_BASE=https://yunmao.net.cn

YUNMAO_ADMIN_BASE_PATH=/admin
NEXT_PUBLIC_ADMIN_API_BASE=https://yunmao.net.cn/admin-api
NEXT_PUBLIC_AUTH_API_BASE=https://yunmao.net.cn/admin-api
