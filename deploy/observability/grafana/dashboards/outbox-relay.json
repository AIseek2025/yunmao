{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Yunmao Outbox Relay",
  "uid": "yunmao-outbox-relay",
  "version": 1,
  "tags": ["yunmao", "outbox", "kafka"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Outbox pending rows",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(yunmao_outbox_relay_pending)", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DLQ rows total",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(yunmao_outbox_relay_dlq_total)", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Published events / sec",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(yunmao_outbox_relay_published_total[1m])", "refId": "A", "legendFormat": "{{topic}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Publish latency (P50 / P95)",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(yunmao_outbox_relay_publish_latency_seconds_bucket[5m])) by (le))", "refId": "A", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(yunmao_outbox_relay_publish_latency_seconds_bucket[5m])) by (le))", "refId": "B", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(yunmao_outbox_relay_publish_latency_seconds_bucket[5m])) by (le))", "refId": "C", "legendFormat": "P99" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Relay retries",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(yunmao_outbox_relay_retry_total[1m])", "refId": "A", "legendFormat": "retry/s" },
        { "expr": "rate(yunmao_outbox_relay_failed_total[1m])", "refId": "B", "legendFormat": "fail/s" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DLQ rate",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "rate(yunmao_outbox_relay_dlq_total[5m])", "refId": "A", "legendFormat": "dlq/s" }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Worker concurrency",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(yunmao_outbox_relay_workers)", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Oldest pending (s)",
      "datasource": { "type": "prometheus", "uid": "yunmao-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "max(yunmao_outbox_relay_oldest_pending_seconds)", "refId": "A" }
      ]
    }
  ]
}
